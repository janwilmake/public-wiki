{
  "$schema": "https://selfdrivingrepo.com/schema.json",
  "branch": "main",
  "agents": [
    {
      "name": "wiki updater",
      "llm_model": "deepseek/deepseek-v3.2",
      "frequency_hours": 168,
      "prompt": "Check the downstream wiki and craft a wiki from the information that is public facing. This means it shouldn't have any personal information like finances, health etc related stuff.",
      "budget_cents": 1000,
      "budget_period": "month",
      "budget_spread": false,
      "tools": {
        "bash": true,
        "diff": true,
        "threads": false,
        "webSearch": false,
        "upstreamRepos": [
          {
            "owner": "janwilmake",
            "repo": "private-wiki",
            "branch": "main"
          }
        ]
      }
    }
  ]
}