{
  "$schema": "https://selfdrivingrepo.com/schema.json",
  "branch": "main",
  "agents": [
    {
      "name": "wiki updater",
      "llm_model": "anthropic/claude-opus-4.6",
      "frequency_hours": 48,
      "prompt": "Check the downstream wiki and craft a wiki from the information that is public facing. This means it. shouldn't have any personal information like finances, health etc related stuff.",
      "budget_cents": 500,
      "budget_period": "week",
      "budget_spread": false,
      "tools": {
        "bash": true,
        "diff": true,
        "threads": false,
        "webSearch": false,
        "upstreamRepos": [
          {
            "owner": "janwilmake",
            "repo": "private-wiki",
            "branch": "main"
          }
        ]
      }
    }
  ]
}
